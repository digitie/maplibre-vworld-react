    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "maplibre-gl": "*",
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.0.0",
    "@types/supercluster": "^7.1.3",
    "typescript": "^5.0.0"
  }
}
